<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:minHeight="620dp"
        android:orientation="vertical"
        android:padding="32dp">

        <ImageView
            android:id="@+id/ivTrofeu"
            android:layout_width="180dp"
            android:layout_height="180dp"
            android:layout_marginBottom="24dp"
            android:contentDescription="Troféu Oscar"
            android:src="@drawable/oscar_trofeu" />

        <TextView
            android:id="@+id/tvBemVindo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="Bem-vindo!"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvToken"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:gravity="center"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/tvStatusVoto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:gravity="center"
            android:text="Voto confirmado. As escolhas estão bloqueadas."
            android:textColor="#2E7D32"
            android:visibility="gone" />

        <Button
            android:id="@+id/btnVotarFilme"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="Votar Filme" />

        <Button
            android:id="@+id/btnVotarDiretor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="Votar Diretor" />

        <Button
            android:id="@+id/btnConfirmarVoto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="Confirmar Voto" />

        <Button
            android:id="@+id/btnSair"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sair" />

    </LinearLayout>
</ScrollView>
